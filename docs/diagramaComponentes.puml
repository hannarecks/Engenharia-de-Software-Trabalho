@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white

package "Frontend React" {

  [DashboardUI]
  [ComparacaoDocsUI]
  [MonitoramentoFinanceiroUI]
  [AlertasUI]
  [TarefasUI]

}

package "Backend Node.js" {

  [API REST]

  [AuthService]

  [ProcessadorDocs]

  [DivergenceReporter]

  [IntegradorPortal]

  [AlertEngine]

  [TaskManager]

  [SupabaseClient]

}

database "Supabase PostgreSQL" as DB

component "Supabase Auth" as AUTH

component "Supabase Storage" as STORAGE

component "Portal da Transparencia" <<external>> as PORTAL


[DashboardUI] --> [API REST] : HTTPS/REST

[ComparacaoDocsUI] --> [API REST] : HTTPS/REST

[MonitoramentoFinanceiroUI] --> [API REST] : HTTPS/REST

[AlertasUI] --> [API REST] : HTTPS/REST

[TarefasUI] --> [API REST] : HTTPS/REST


[API REST] --> [AuthService]

[API REST] --> [ProcessadorDocs]

[API REST] --> [DivergenceReporter]

[API REST] --> [IntegradorPortal]

[API REST] --> [AlertEngine]

[API REST] --> [TaskManager]


[AuthService] --> AUTH : JWT

[ProcessadorDocs] --> [SupabaseClient]

[DivergenceReporter] --> [SupabaseClient]

[AlertEngine] --> [SupabaseClient]

[TaskManager] --> [SupabaseClient]

[IntegradorPortal] --> PORTAL : REST API

[SupabaseClient] --> DB : REST API

[SupabaseClient] --> STORAGE : Upload/Download PDF

@enduml