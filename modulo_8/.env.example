# Onde pegar os valores reais: painel do Supabase →
# Project Settings → API → "Project URL" e "anon public key".

# ATENÇÃO: use apenas a "anon public key" não outro tipo!

# URL do projeto Supabase
VUE_APP_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública (anon key), protegida pelas políticas de RLS.
# Não é a chave "service_role"!
VUE_APP_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# TODO: quando a integração com o Portal da Transparência estiver
# implementada, adicionar aqui a variável correspondente
# ex: VUE_APP_PORTAL_TRANSPARENCIA_API_KEY=
